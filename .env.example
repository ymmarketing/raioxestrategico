# ═══════════════════════════════════════════════════════════════════
#  VARIÁVEIS DE AMBIENTE — Raio-X Estratégico (backend na Vercel)
#
#  ⚠  Este arquivo é só um MODELO. Não coloque chave real aqui.
#     Nunca suba um .env preenchido para o GitHub.
#     Cadastre os valores em: Vercel → Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════════


# ── ASAAS ────────────────────────────────────────────────────────────
# Chave de API. Produção começa com $aact_prod_ , sandbox com $aact_hmlg_
# Onde pegar: painel do Asaas → Integrações → Chave de API
# (a chave só aparece UMA vez; copie e guarde)
ASAAS_API_KEY=

# Token do webhook. VOCÊ inventa este valor (uma senha longa e aleatória),
# cadastra igual nos dois lugares: aqui e no painel do Asaas.
# Requisitos do Asaas: token forte, sem sequências (12345) nem 4 letras repetidas.
# Sugestão: 40 caracteres aleatórios. Ex. de formato: whsec_xxxxxxxx...
ASAAS_WEBHOOK_TOKEN=

# sandbox     → https://api-sandbox.asaas.com/v3  (teste, dinheiro fictício)
# production  → https://api.asaas.com/v3           (cobra de verdade)
#
# COMECE PELO SANDBOX. Só troque para production depois de testar tudo.
ASAAS_ENV=sandbox


# ── ANTHROPIC (redação do relatório) ─────────────────────────────────
# Onde pegar: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Opcionais (têm padrão no código)
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MAX_TOKENS=4000


# ── UPSTASH REDIS (guarda o status do pagamento) ─────────────────────
# Onde pegar: console.upstash.com → crie um banco Redis → aba "REST API"
# O plano gratuito é suficiente para começar.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ── PRODUTO ──────────────────────────────────────────────────────────
PRODUCT_PRICE=97
PRODUCT_NAME=Raio-X Estratégico


# ── URLS ─────────────────────────────────────────────────────────────
# URL onde o BACKEND roda (a da Vercel)
PUBLIC_BASE_URL=https://SEU-PROJETO.vercel.app

# URL onde o SITE roda (GitHub Pages ou domínio próprio).
# Usada para montar o link de retorno do Asaas:  {SITE_URL}/?ref=...
# Se ficar vazia, o cliente não volta automaticamente após pagar —
# o polling ainda funciona se ele mantiver a aba aberta.
SITE_URL=https://seusite.github.io

# Origens autorizadas a chamar a API, separadas por vírgula.
# Inclua o endereço do site (GitHub Pages) E o da própria Vercel.
# Exemplo:
# ALLOWED_ORIGINS=https://seuusuario.github.io,https://raioxestrategico.vercel.app
ALLOWED_ORIGINS=


# ── SEGURANÇA ────────────────────────────────────────────────────────
# true  (padrão) → /api/relatorio só gera para quem tem pagamento aprovado.
#                  Protege sua cota da Anthropic.
# false          → qualquer um pode gerar relatório. Use só para teste.
REQUER_PAGAMENTO_RELATORIO=true

# CÓDIGO-MESTRE — acesso de teste, sem pagar.
#
#   STAGING   → preencha com o seu código (ex.: YM-MASTER-XXXXXX)
#   PRODUÇÃO  → deixe VAZIO ou não cadastre. A rota nega tudo.
#
# ⚠ Em produção, use index.production.html (que nem tenta usar esta rota).
CODIGO_MESTRE=

# Sal usado para conferir os códigos de acesso.
# Precisa ser IGUAL ao SALT do arquivo gerar_codigos.py.
# Se mudar aqui, os 20 códigos antigos param de funcionar.
CODIGO_SALT=YM-RAIOX-2026
